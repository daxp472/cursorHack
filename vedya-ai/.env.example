# VedyaAI Environment Configuration
# Copy this to .env and fill in your values — never commit real secrets.

# ── Database ──────────────────────────────────────
DATABASE_URL=postgresql://vedya:vedyapass@localhost:5433/vedyaai

# ── OpenAI (dynamic EN/HI/GU clinical explanations & translations) ──
# Put your key here. When set and LLM_ENABLED=true, explanations + details localize dynamically.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LLM_ENABLED=true

# ── Auth ──────────────────────────────────────────
JWT_SECRET=vedya-dev-secret-change-me-in-production
JWT_EXPIRE_HOURS=72

# ── App config ────────────────────────────────────
CORPUS_VERSION=1.0.0

# ── Frontend ──────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── ElevenLabs voice (Listen / Speak case / STT) ───
# Put your ElevenLabs API key here. Without it, UI shows Voice off.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_TTS_MODEL=eleven_multilingual_v2
ELEVENLABS_STT_MODEL=scribe_v2
